# ── DATABASE ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host:5432/dbname
# Use DATABASE_PUBLIC_URL for local dev if on Railway

# ── AI ────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_key_here

# ── TELEGRAM ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ── APIFY (SCRAPING) ──────────────────────────────────────────────────────────
APIFY_API_KEY=apify_api_XXXXXXXXXXXX
# SCRAPE_LIMIT=15     # items per search per run — keep low for testing
# SCRAPE_LIMIT=50     # bump this for production

# ── PLATFORMS ────────────────────────────────────────────────────────────────
CITIES=toronto
KIJIJI_EMAIL=your@email.com
KIJIJI_PASSWORD=your_kijiji_password
FB_EMAIL=your@email.com
FB_PASSWORD=your_fb_password

# ── EBAY (OPTIONAL — free official API, no Apify cost) ───────────────────────
# EBAY_APP_ID=your_ebay_app_id
# EBAY_CLIENT_SECRET=your_ebay_secret
