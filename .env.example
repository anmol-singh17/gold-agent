# Copy to .env and fill in. NEVER commit .env to git.

# Railway PostgreSQL — use DATABASE_PUBLIC_URL for local testing
DATABASE_URL=postgresql://postgres:PASSWORD@HOST:PORT/railway

# Gemini API — aistudio.google.com → Get API Key
GEMINI_API_KEY=AIza...

# Telegram — @BotFather → /newbot → send msg to bot → getUpdates for chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Cities
CITIES=toronto

# FB SECONDARY account ONLY — never your real account
FB_EMAIL=
FB_PASSWORD=

# Kijiji account
KIJIJI_EMAIL=
KIJIJI_PASSWORD=

# eBay Canada API (optional, free) — developer.ebay.com → Create App
EBAY_APP_ID=
EBAY_CLIENT_SECRET=

# Auto-populated by session_setup.py — paste into Railway/Render env vars
FACEBOOK_SESSION_B64=
KIJIJI_SESSION_B64=
